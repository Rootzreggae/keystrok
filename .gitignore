# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only working artifacts. This repo is now the public "home"; these dirs
# and docs stay on disk for reference but are never published. Their full
# history lives in the private archive-private remote if you ever need it.
/design/
/archive/
/test-scanner/
/SECURITY_AUDIT_REPORT.md
/SECURITY_REVIEW_COMPLETE.md
/SECURITY_SCHEMA_DESIGN.md
/SERVER_HEALTH_REPORT.txt

# Synthetic secret fixtures for scanner testing, never commit
test-fixtures/
