# next-auth@5 (beta) peer-requires nodemailer@^7, while @auth/core (via
# @auth/prisma-adapter) peer-requires nodemailer@^6. Those constraints are
# mutually incompatible, so a strict `npm install` ERESOLVE-fails. nodemailer 6
# and 7 are API-compatible for our usage (createTransport/sendMail), so we keep
# 6 and tell npm to accept the conflicting (optional) peer. This is what makes
# `npm install` succeed on Vercel/CI/Docker, without it every deploy fails at
# the install step.
legacy-peer-deps=true
