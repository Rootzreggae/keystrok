# Keystrok environment template, copy to .env.local and fill in.
# NEVER commit a real .env / .env.local (they are gitignored). Only this template is tracked.

# --- Database (PostgreSQL) ---------------------------------------------------
# Any Postgres works (local, Neon, RDS, etc.). For local self-hosting:
#   postgresql://keystrok:keystrok@localhost:5432/keystrok
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/keystrok"
# Only used by the bundled docker-compose Postgres. Defaults to "keystrok";
# set a real password for any non-loopback / production deployment.
# POSTGRES_PASSWORD="change-me"

# --- NextAuth ----------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3001"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_ME"

# --- Encryption at rest ------------------------------------------------------
# Encrypts platform API keys before they are stored (AES-256-GCM).
# Must decode to exactly 32 bytes. Generate with: openssl rand -base64 32
# Rotating this key requires re-encrypting existing rows (see scripts/).
ENCRYPTION_KEY="REPLACE_ME"

# --- Access control (invite-only by default) ---------------------------------
# Only approved emails may sign in. Approve someone by listing them here, by
# allowing their whole domain, or by running scripts/allow-user.ts (waitlist).
ALLOWED_EMAILS="you@example.com"
ALLOWED_EMAIL_DOMAINS=""
# Self-host operators who want anyone to register on their own instance:
AUTH_OPEN_REGISTRATION="false"

# --- Outbound request safety (SSRF) ------------------------------------------
# The connection-test fetches user-configured platform URLs server-side. By
# default, internal/private/metadata targets are blocked. If you self-host and
# legitimately point at internal observability hosts (e.g. a Grafana on a
# private IP), set this to "true". Scheme (http/https) is always enforced.
ALLOW_PRIVATE_PLATFORM_URLS="false"

# --- Email (magic-link sign-in + waitlist confirmation) ----------------------
# Transport selector. Leave unset to auto-pick: Resend if RESEND_API_KEY is set,
# else SMTP if EMAIL_SERVER_HOST is set. Force one with "smtp" or "resend".
EMAIL_TRANSPORT=""

# SMTP, any server works. For local dev the docker-compose stack runs a
# MailHog-style catcher (Mailpit): host "mailpit", port 1025, no auth. Leave
# EMAIL_SERVER_USER empty to send without authentication.
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="REPLACE_ME"
EMAIL_SERVER_PASSWORD="REPLACE_ME"
EMAIL_FROM="Keystrok <no-reply@example.com>"

# Resend (hosted email API), alternative to SMTP. Set this and the mailer
# sends via Resend instead. The "from" address must be on a Resend-verified
# domain.
RESEND_API_KEY=""

# --- GitHub source scanning (optional) ----------------------------------------
# Connect GitHub repos and scan them for exposed keys. Easiest path: leave these
# unset and use the in-app setup (Discovery > Connect a source), which registers
# a GitHub App via the manifest flow and stores its credentials encrypted in the
# database. Set these only if you registered a GitHub App by hand.
# GITHUB_APP_ID=""
# GITHUB_APP_SLUG=""
# Private key PEM, base64-encoded: base64 < your-app.private-key.pem
# GITHUB_APP_PRIVATE_KEY_BASE64=""

# --- Scheduled jobs -----------------------------------------------------------
# Shared secret protecting the cron endpoints (/api/cron/tick for key liveness
# and alerts, /api/cron/scan for continuous re-scans of connected repos). Point
# any scheduler at them, e.g.:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-host/api/cron/scan
# Endpoints fail closed if this is unset. Generate with: openssl rand -hex 32
CRON_SECRET="REPLACE_ME"
